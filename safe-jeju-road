function analyzeRouteRisk(coords){
  let zoneStats = {};
  let totalScore = 0;
  let totalDistanceKm = 0;

  for(let i = 0; i < coords.length - 1; i++){
    const p1 = coords[i];
    const p2 = coords[i + 1];

    const segmentKm = getDistanceKm(p1[0], p1[1], p2[0], p2[1]);
    totalDistanceKm += segmentKm;

    const midLat = (p1[0] + p2[0]) / 2;
    const midLng = (p1[1] + p2[1]) / 2;

    dangerZones.forEach(zone=>{
      const d = getDistanceKm(midLat, midLng, zone.lat, zone.lng);

      if(d <= zone.radiusKm){
        const segmentScore = zone.epdo * segmentKm;
        totalScore += segmentScore;

        if(!zoneStats[zone.name]){
          zoneStats[zone.name] = {
            name: zone.name,
            distanceKm: 0,
            score: 0,
            epdo: zone.epdo,
            count: zone.count,
            reason: zone.reason
          };
        }

        zoneStats[zone.name].distanceKm += segmentKm;
        zoneStats[zone.name].score += segmentScore;
      }
    });
  }

  const passedZones = Object.values(zoneStats)
    .sort((a,b)=>b.score - a.score);

  if(passedZones.length === 0){
    return {
      score:0,
      level:"낮음",
      icon:"🟢",
      zoneNames:"사고밀집권역 통과 적음",
      reasons:"비교적 단순한 경로",
      totalCount:0,
      totalEpdo:0,
      totalDistanceKm: totalDistanceKm,
      riskScoreText:"0점",
      zoneDetailText:"사고밀집권역 통과 적음"
    };
  }

  let level = "낮음";
  let icon = "🟢";

  if(totalScore >= 2500){
    level = "매우높음";
    icon = "🔴";
  }else if(totalScore >= 1200){
    level = "높음";
    icon = "🟠";
  }else if(totalScore >= 500){
    level = "보통";
    icon = "🟡";
  }

  const totalCount = passedZones.reduce((sum,z)=>sum + z.count, 0);
  const totalEpdo = passedZones.reduce((sum,z)=>sum + z.epdo, 0);

  const zoneNames = passedZones
    .map(z => z.name + " " + z.distanceKm.toFixed(1) + "km")
    .join(", ");

  const zoneDetailText = passedZones
    .map(z =>
      z.name +
      " " +
      z.distanceKm.toFixed(1) +
      "km × EPDO " +
      z.epdo +
      " = " +
      Math.round(z.score).toLocaleString() +
      "점"
    )
    .join("<br>");

  return {
    score: totalScore,
    level: level,
    icon: icon,
    zoneNames: zoneNames,
    reasons: passedZones.map(z=>z.reason).join(" / "),
    totalCount: totalCount,
    totalEpdo: totalEpdo,
    totalDistanceKm: totalDistanceKm,
    riskScoreText: Math.round(totalScore).toLocaleString() + "점",
    zoneDetailText: zoneDetailText
  };
}

function getDistanceKm(lat1,lng1,lat2,lng2){
  const R = 6371;
  const dLat = deg2rad(lat2-lat1);
  const dLng = deg2rad(lng2-lng1);

  const a =
    Math.sin(dLat/2) * Math.sin(dLat/2) +
    Math.cos(deg2rad(lat1)) *
    Math.cos(deg2rad(lat2)) *
    Math.sin(dLng/2) *
    Math.sin(dLng/2);

  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
  return R * c;
}

function deg2rad(deg){
  return deg * (Math.PI/180);
}

