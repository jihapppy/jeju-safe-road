function getJejuRegion(name){

  if(!name) return "기타";

  // ① 공항권
  if(
    name.includes("용담1동") ||
    name.includes("용담2동") ||
    name.includes("도두동") ||
    name.includes("이호동")
  ) return "공항권";

  // ② 제주시도심권
  if(
    name.includes("연동") ||
    name.includes("노형동") ||
    name.includes("건입동") ||
    name.includes("일도1동") ||
    name.includes("일도2동") ||
    name.includes("이도1동") ||
    name.includes("이도2동") ||
    name.includes("삼도1동") ||
    name.includes("삼도2동")
  ) return "제주시도심권";

  // ③ 함덕·조천권
  if(
    name.includes("조천읍") ||
    name.includes("삼양동") ||
    name.includes("화북동")
  ) return "함덕·조천권";

  // ④ 김녕·월정권
  if(
    name.includes("구좌읍")
  ) return "김녕·월정권";

  // ⑤ 성산권
  if(
    name.includes("성산읍") ||
    name.includes("우도면")
  ) return "성산권";

  // ⑥ 애월권
  if(
    name.includes("애월읍") ||
    name.includes("외도동")
  ) return "애월권";

  // ⑦ 협재·한림권
  if(
    name.includes("한림읍")
  ) return "협재·한림권";

  // ⑧ 중문권
  if(
    name.includes("중문동") ||
    name.includes("대천동") ||
    name.includes("예래동")
  ) return "중문권";

 // ⑨ 서귀포도심권
if(
  name.includes("동홍동") ||
  name.includes("서홍동") ||
  name.includes("송산동") ||
  name.includes("정방동") ||
  name.includes("중앙동") ||
  name.includes("천지동") ||
  name.includes("대륜동") ||
  name.includes("영천동") ||
  name.includes("효돈동")
) return "서귀포도심권";

// ⑩ 서부중산간권
if(
  name.includes("안덕면") ||
  name.includes("대정읍") ||
  name.includes("한경면")
) return "서부중산간권";

// ⑪ 동부중산간권
if(
  name.includes("표선면") ||
  name.includes("남원읍")
) return "동부중산간권";

  // ⑫ 한라산권
  if(
    name.includes("아라동") ||
    name.includes("오라동") ||
    name.includes("봉개동")
  ) return "한라산권";

  return "기타";
}

